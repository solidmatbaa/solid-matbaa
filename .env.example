# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Default tenant (multi-tenant ready)
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=solid-matbaa

# Resend (Email Verification)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM="Solid Matbaa <noreply@solidmatbaa.com>"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Fixed bank transfer IBAN (optional — overrides DB settings; read-only in admin)
NEXT_PUBLIC_SITE_IBAN=

# Default admin (auto-created on server startup if missing)
# Required only when the admin auth user does not exist yet
ADMIN_INITIAL_PASSWORD=choose-a-strong-password
# Optional: secret for POST /api/admin/init (header: x-admin-init-secret)
ADMIN_INIT_SECRET=your-random-init-secret
